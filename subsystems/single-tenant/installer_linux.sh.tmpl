#!/usr/bin/env bash
# RustDesk pre-configured installer — @@DISPLAY_NAME@@
# Generated by RustDesk Fleet Manager
#
# Run as root:   sudo bash RemoteSupport-@@GROUP_SLUG@@-@@RUSTDESK_VERSION@@-linux.sh
#
# Supports: Debian/Ubuntu (.deb), Fedora/RHEL/CentOS (.rpm)
#           Architectures: x86_64, aarch64
set -euo pipefail

HOST="@@HOST@@"
KEY="@@PUBKEY@@"
RDVER="@@RUSTDESK_VERSION@@"
@@PASSWORD_VAR@@

# ── Detect architecture ─────────────────────────────────────────────────
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)        DEB_ARCH="x86_64";  RPM_ARCH="x86_64"  ;;
  aarch64|arm64) DEB_ARCH="aarch64"; RPM_ARCH="aarch64"  ;;
  *) echo "Unsupported architecture: $ARCH" >&2; exit 1   ;;
esac

# ── Detect package manager ──────────────────────────────────────────────
if   command -v apt-get &>/dev/null; then PKG_TYPE=deb
elif command -v dnf     &>/dev/null; then PKG_TYPE=rpm; PM=dnf
elif command -v yum     &>/dev/null; then PKG_TYPE=rpm; PM=yum
else echo "No supported package manager found (apt/dnf/yum)." >&2; exit 1
fi

# ── Write RustDesk2.toml ────────────────────────────────────────────────
write_config() {
  mkdir -p "$1"
  {
    printf 'rendezvous_server = "%s"\n' "$HOST"
    printf '\n[options]\n'
    printf 'custom-rendezvous-server = "%s"\n' "$HOST"
    printf 'relay-server = "%s"\n' "$HOST"
    printf 'key = "%s"\n' "$KEY"
@@PASSWORD_LINE_SHELL@@  } > "$1/RustDesk2.toml"
  echo "  Config → $1/RustDesk2.toml"
}

echo "Writing config…"
write_config "/root/.config/rustdesk"
[ -n "${SUDO_USER:-}" ] && write_config "/home/$SUDO_USER/.config/rustdesk"

# ── Download and install ────────────────────────────────────────────────
TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT

if [ "$PKG_TYPE" = deb ]; then
  PKG="rustdesk-${RDVER}-${DEB_ARCH}.deb"
  URL="https://github.com/rustdesk/rustdesk/releases/download/${RDVER}/${PKG}"
  echo "Downloading ${PKG}…"
  curl -fsSL --progress-bar "$URL" -o "$TMP/$PKG"
  echo "Installing…"
  apt-get install -y "$TMP/$PKG" 2>/dev/null \
    || { dpkg -i "$TMP/$PKG" || true; apt-get install -fy 2>/dev/null; }
else
  PKG="rustdesk-${RDVER}-0.${RPM_ARCH}.rpm"
  URL="https://github.com/rustdesk/rustdesk/releases/download/${RDVER}/${PKG}"
  echo "Downloading ${PKG}…"
  curl -fsSL --progress-bar "$URL" -o "$TMP/$PKG"
  echo "Installing…"
  ${PM:-rpm} install -y "$TMP/$PKG" 2>/dev/null || rpm -Uvh "$TMP/$PKG"
fi

# Re-write config after install (package may have created defaults)
echo "Re-applying config…"
write_config "/root/.config/rustdesk"
[ -n "${SUDO_USER:-}" ] && write_config "/home/$SUDO_USER/.config/rustdesk"

# ── Enable and start service ────────────────────────────────────────────
systemctl enable rustdesk 2>/dev/null || true
systemctl restart rustdesk 2>/dev/null || true

echo ""
echo "✓ RustDesk ${RDVER} installed and configured → ${HOST}"
rustdesk --version 2>/dev/null || true
