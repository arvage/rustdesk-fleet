; RustDesk pre-configured installer — built by generate_installer.py.
; @@PLACEHOLDER@@ markers are substituted at build time; do not edit them here.
;
; Install sequence:
;   1. Pre-write RustDesk2.toml to all config locations BEFORE launching
;      the RustDesk installer, so the service reads the right server on first start.
;   2. Run the official RustDesk installer with --silent-install and wait.
;      The binary spawns a background child and exits early, so we poll for
;      the installed EXE rather than sleeping a fixed amount.
;   3. Stop the service and tray app, re-write config everywhere (the installer
;      may have overwritten our settings during startup), then restart.
;
; WOW64 note: this is a 32-bit NSIS installer running on 64-bit Windows.
;   Writing $WINDIR\System32 from a 32-bit process is silently redirected
;   to SysWOW64.  We disable that redirection around the System32 write so
;   the file lands where the 64-bit RustDesk service actually reads it.
;   ProgramData ($APPDATA with SetShellVarContext all) has no such redirection.

Unicode True
RequestExecutionLevel admin
SetCompressor /SOLID lzma
ShowInstDetails nevershow
AutoCloseWindow true

!include "x64.nsh"

Name "@@DISPLAY_NAME@@ Remote Support"
OutFile "@@OUTPUT_PATH@@"

; Write RustDesk2.toml to the given directory (caller sets shell var context)
!macro WriteConfig path
  CreateDirectory "${path}"
  FileOpen $0 "${path}\RustDesk2.toml" w
  FileWrite $0 'rendezvous_server = "@@HOST@@"$\r$\n'
  FileWrite $0 '$\r$\n'
  FileWrite $0 '[options]$\r$\n'
  FileWrite $0 'custom-rendezvous-server = "@@HOST@@"$\r$\n'
  FileWrite $0 'relay-server = "@@HOST@@"$\r$\n'
  FileWrite $0 'key = "@@PUBKEY@@"$\r$\n'
@@PASSWORD_LINE@@  FileClose $0
!macroend

Section "Install"

  ; ── Step 1: pre-write config ───────────────────────────────────────────────

  ; Current user's Roaming AppData
  SetShellVarContext current
  !insertmacro WriteConfig "$APPDATA\RustDesk\config"

  ; ProgramData (All Users AppData) — accessible to the service, no WOW64 issues
  SetShellVarContext all
  !insertmacro WriteConfig "$APPDATA\RustDesk\config"
  SetShellVarContext current

  ; SYSTEM account profile inside the real 64-bit System32.
  ; A 32-bit NSIS process gets silently redirected to SysWOW64 for System32
  ; writes — disable that so our file reaches the path the service reads.
  ${DisableX64FSRedirection}
  !insertmacro WriteConfig "$WINDIR\System32\config\systemprofile\AppData\Roaming\RustDesk\config"
  ${EnableX64FSRedirection}

  ; ── Step 2: run the RustDesk installer ────────────────────────────────────
  SetOutPath "$TEMP"
  File "@@RUSTDESK_EXE_SRC@@"
  ExecWait '"$TEMP\@@RUSTDESK_EXE_NAME@@" --silent-install'

  ; The installer spawns a background child that does the real work and exits.
  ; Poll for the installed EXE (up to 30 s) rather than using a fixed sleep.
  StrCpy $1 0
  poll:
    IfFileExists "$PROGRAMFILES64\RustDesk\rustdesk.exe" install_ok
    IntCmp $1 30 install_failed
    Sleep 1000
    IntOp $1 $1 + 1
    Goto poll

  install_failed:
    MessageBox MB_OK|MB_ICONSTOP \
      "RustDesk did not install correctly.$\n$\nPlease make sure you are running this installer as Administrator and try again."
    Delete "$TEMP\@@RUSTDESK_EXE_NAME@@"
    Abort

  install_ok:

  ; ── Step 3: stop, re-write config, restart ────────────────────────────────
  ; The RustDesk installer may have started the service with defaults and
  ; written its own config.  Kill processes, overwrite with ours, then restart.
  nsExec::ExecToLog 'taskkill /F /IM rustdesk.exe'
  Pop $0
  nsExec::ExecToLog 'net stop RustDesk'
  Pop $0

  SetShellVarContext current
  !insertmacro WriteConfig "$APPDATA\RustDesk\config"

  SetShellVarContext all
  !insertmacro WriteConfig "$APPDATA\RustDesk\config"
  SetShellVarContext current

  ${DisableX64FSRedirection}
  !insertmacro WriteConfig "$WINDIR\System32\config\systemprofile\AppData\Roaming\RustDesk\config"
  ${EnableX64FSRedirection}

  ; Restart the service then launch the tray app
  nsExec::ExecToLog 'net start RustDesk'
  Pop $0
  Exec '"$PROGRAMFILES64\RustDesk\rustdesk.exe"'

  Delete "$TEMP\@@RUSTDESK_EXE_NAME@@"
SectionEnd
