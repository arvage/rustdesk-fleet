#!/usr/bin/env bash
# RustDesk pre-configured installer — @@DISPLAY_NAME@@
# Generated by RustDesk Fleet Manager
#
# HOW TO RUN:
#   Right-click this file → Open → click Open in the Gatekeeper dialog.
#   Or remove the quarantine flag first:
#     xattr -d com.apple.quarantine RemoteSupport-@@GROUP_SLUG@@-@@RUSTDESK_VERSION@@-macos.command
#     bash RemoteSupport-@@GROUP_SLUG@@-@@RUSTDESK_VERSION@@-macos.command
set -euo pipefail

HOST="@@HOST@@"
KEY="@@PUBKEY@@"
RDVER="@@RUSTDESK_VERSION@@"
@@PASSWORD_VAR@@

# ── Write config files ──────────────────────────────────────────────────
# RustDesk2.toml holds server/options (Config2 struct).
# RustDesk.toml holds the permanent password (Config struct, top-level "password" field).
CONFIG_DIR="$HOME/Library/Application Support/RustDesk/config"

write_config() {
  mkdir -p "$1"
  {
    printf 'rendezvous_server = "%s"\n' "$HOST"
    printf '\n[options]\n'
    printf 'custom-rendezvous-server = "%s"\n' "$HOST"
    printf 'relay-server = "%s"\n' "$HOST"
    printf 'key = "%s"\n' "$KEY"
  } > "$1/RustDesk2.toml"
  {
    printf '[options]\n'
    printf 'custom-rendezvous-server = "%s"\n' "$HOST"
    printf 'relay-server = "%s"\n' "$HOST"
    printf 'key = "%s"\n' "$KEY"
  } > "$1/_local.toml"
  echo "  Config → $1/RustDesk2.toml + _local.toml"
@@PASSWORD_CONFIG_WRITE_SHELL@@}

echo "Writing config…"
write_config "$CONFIG_DIR"

# ── Download RustDesk DMG ───────────────────────────────────────────────
TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT

# RustDesk ships a universal (Intel + Apple Silicon) DMG
DMG="rustdesk-${RDVER}.dmg"
URL="https://github.com/rustdesk/rustdesk/releases/download/${RDVER}/${DMG}"

echo "Downloading RustDesk ${RDVER}…"
curl -fL --progress-bar "$URL" -o "$TMP/$DMG"

# ── Mount, copy app, unmount ────────────────────────────────────────────
MNT=$(mktemp -d)
hdiutil attach "$TMP/$DMG" -mountpoint "$MNT" -nobrowse -quiet

echo "Installing RustDesk.app to /Applications…"
cp -R "$MNT/RustDesk.app" /Applications/

hdiutil detach "$MNT" -quiet || true

# Remove quarantine so Gatekeeper does not block the first launch
xattr -dr com.apple.quarantine /Applications/RustDesk.app 2>/dev/null || true

# Re-write config (app may create a default config on first launch)
echo "Re-applying config…"
write_config "$CONFIG_DIR"

# ── Install LaunchAgent for auto-start on login ─────────────────────────
AGENTS="$HOME/Library/LaunchAgents"
PLIST="$AGENTS/com.carriez.rustdesk.plist"
mkdir -p "$AGENTS"
cat > "$PLIST" << 'PLIST_EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.carriez.rustdesk</string>
  <key>ProgramArguments</key>
  <array><string>/Applications/RustDesk.app/Contents/MacOS/rustdesk</string></array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/rustdesk.log</string>
  <key>StandardErrorPath</key><string>/tmp/rustdesk.log</string>
</dict>
</plist>
PLIST_EOF

launchctl unload "$PLIST" 2>/dev/null || true
launchctl load  "$PLIST" 2>/dev/null || true

# ── Set permanent password via RustDesk CLI ─────────────────────────────
# RustDesk.toml already has "password = ..." (plaintext, legacy auth path).
# The CLI call upgrades it to a proper hash via IPC to the running service.
if [ -n "${PW:-}" ]; then
  sleep 1
  /Applications/RustDesk.app/Contents/MacOS/rustdesk --password "$PW" 2>/dev/null || true
fi

echo ""
echo "✓ RustDesk ${RDVER} installed and configured → ${HOST}"
echo "  RustDesk will start automatically on login."
echo ""
echo "Opening RustDesk…"
open /Applications/RustDesk.app
