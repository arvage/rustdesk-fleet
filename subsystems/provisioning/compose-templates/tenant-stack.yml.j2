# Auto-generated by provisioning/allocate_tenant.py — do not hand-edit.
# Tenant: {{ slug }}  (port_index={{ port_index }})
#
# Port scheme: base = {{ hbbs_port }}
#   hbbs:  {{ hbbs_port }}      TCP  ID/signaling
#          {{ hbbs_port + 1 }}  TCP+UDP  heartbeat / NAT traversal
#          {{ hbbs_port + 3 }}  TCP  web client support
#   hbbr:  {{ hbbr_port }}      TCP  relay
#          {{ hbbr_port + 2 }}  TCP  relay (web client)
#
# NOTE: deliberately NOT using network_mode: host, since this host runs
# multiple tenants. Each tenant is isolated to its own port block instead.

services:
  hbbs-{{ slug }}:
    image: rustdesk/rustdesk-server:{{ rustdesk_server_tag }}
    container_name: hbbs-{{ slug }}
    command: hbbs -p {{ hbbs_port }}
    ports:
      - "{{ hbbs_port }}:{{ hbbs_port }}"
      - "{{ hbbs_port + 1 }}:{{ hbbs_port + 1 }}"
      - "{{ hbbs_port + 1 }}:{{ hbbs_port + 1 }}/udp"
      - "{{ hbbs_port + 3 }}:{{ hbbs_port + 3 }}"
    volumes:
      - {{ data_dir }}/data:/root
    restart: unless-stopped
    depends_on:
      - hbbr-{{ slug }}
    labels:
      - "fleet.tenant={{ slug }}"
      - "fleet.role=hbbs"

  hbbr-{{ slug }}:
    image: rustdesk/rustdesk-server:{{ rustdesk_server_tag }}
    container_name: hbbr-{{ slug }}
    command: hbbr -p {{ hbbr_port }}
    ports:
      - "{{ hbbr_port }}:{{ hbbr_port }}"
      - "{{ hbbr_port + 2 }}:{{ hbbr_port + 2 }}"
    volumes:
      - {{ data_dir }}/data:/root
    restart: unless-stopped
    labels:
      - "fleet.tenant={{ slug }}"
      - "fleet.role=hbbr"
